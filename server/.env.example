# Server
PORT=5000
MONGO_URI=
JWT_SECRET=your-secret-key
CLIENT_URL=http://localhost:5173

# Calendly API
# Personal Access Token from Calendly account settings
CALENDLY_API_TOKEN=

# Optional owner overrides (URI values from Calendly API resources)
# Example: https://api.calendly.com/users/AAAAAAAAAAAAAAAA
CALENDLY_USER_URI=
# Example: https://api.calendly.com/organizations/BBBBBBBBBBBBBBBB
CALENDLY_ORGANIZATION_URI=

# Backward-compatible aliases (optional)
# CALENDLY_USER=
# CALENDLY_OWNER_URI=
# CALENDLY_ORGANIZATION=
# CALENDLY_ORG_URI=

